{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "removeComments": true,
    "emitDeclarationOnly": false,
    "stripInternal": true,
    "noEmit": false,
    "incremental": false,
    "composite": false,
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "index.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    ".nyc_output",
    "test/**/*",
    "**/*.d.ts"
  ]
}
