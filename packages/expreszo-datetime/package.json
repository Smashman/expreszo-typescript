{
  "name": "@pro-fa/expreszo-datetime",
  "version": "0.2.1",
  "description": "Optional Luxon-backed date/time functions for the @pro-fa/expreszo expression evaluator.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build:esm": "cross-env BUILD_TARGET=esm vite build",
    "build:umd": "cross-env BUILD_TARGET=umd vite build",
    "build:umd-min": "cross-env BUILD_TARGET=umd-min vite build",
    "build": "npm run build:esm && npm run build:umd && npm run build:umd-min",
    "test": "npm run build:esm && vitest run",
    "test:watch": "vitest",
    "coverage": "npm run build:esm && vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "expreszo",
    "expression",
    "datetime",
    "luxon",
    "plugin"
  ],
  "peerDependencies": {
    "@pro-fa/expreszo": "^0.6.1"
  },
  "dependencies": {
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@types/node": "^24.5.2",
    "cross-env": "^7.0.3",
    "rimraf": "^5.0.10",
    "terser": "^5.44.1",
    "typescript": "^5.9.2",
    "vite": "^6.0.1",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.0"
  }
}
