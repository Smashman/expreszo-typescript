{
  "name": "@pro-fa/expreszo-mcp-server",
  "version": "0.1.0",
  "description": "MCP (Model Context Protocol) server exposing the @pro-fa/expreszo language service to AI assistants.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "expreszo-mcp": "dist/bin.mjs"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "cross-env BUILD_TARGET=esm vite build",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "mcp:dev": "tsx src/bin.ts"
  },
  "keywords": [
    "expreszo",
    "mcp",
    "language-server",
    "ai"
  ],
  "dependencies": {
    "@pro-fa/expreszo": "^0.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "cross-env": "^7.0.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^6.0.1",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.2.4"
  }
}
